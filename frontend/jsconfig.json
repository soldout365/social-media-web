{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@pages/*": ["./pages/*"],
      "@hooks/*": ["./hooks/*"],
      "@store/*": ["./store/*"],
      "@apis/*": ["./apis/*"],
      "@utils/*": ["./utils/*"],
      "@lib/*": ["./lib/*"],
      "@layouts/*": ["./layouts/*"],
      "@assets/*": ["./assets/*"],
      "@types/*": ["./types/*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
